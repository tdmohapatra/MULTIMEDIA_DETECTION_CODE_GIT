@{
    ViewData["Title"] = "Real-Time Human Tracking & Behavior Analysis";
    var apiBaseUrl = (ViewData["ApiBaseUrl"]?.ToString() ?? "http://localhost:5078").TrimEnd('/');
}

<style>
    .live-shell {
        background: linear-gradient(145deg, #0a0f1a, #111a2b);
        color: #f2f7ff;
        border: 1px solid #2a3d63;
    }

    .live-stack {
        position: relative;
        width: 100%;
        border-radius: 12px;
        overflow: hidden;
        border: 1px solid #2b3b61;
        background: #050914;
        min-height: 360px;
    }

    .live-video,
    .live-overlay {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
    }

    .live-overlay {
        pointer-events: none;
    }

    .hud {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
        margin-top: 10px;
    }

    .hud-badge {
        font-size: 12px;
        padding: 4px 8px;
        border-radius: 999px;
        background: #1a2945;
        border: 1px solid #3a5b91;
        color: #f4f9ff;
    }

    .ops-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 8px;
    }

    .monitor-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 12px;
    }

    .monitor-title {
        font-size: 12px;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: #cde0ff;
        margin-bottom: 6px;
    }

    .trail-stack {
        margin-top: 12px;
        border: 1px solid #2b3b61;
        border-radius: 12px;
        background: #060b17;
        padding: 10px;
    }

    /* Full-frame aspect ratio: internal canvas matches video; CSS scales uniformly for accurate trails */
    .trail-canvas-wrap {
        width: 100%;
        max-height: min(62vh, 720px);
        margin: 0 auto;
        position: relative;
        border: 1px solid #30456f;
        border-radius: 10px;
        background: #040812;
        overflow: hidden;
        aspect-ratio: 16 / 9;
        box-shadow: inset 0 0 0 1px rgba(48, 69, 111, 0.35);
    }

    .trail-canvas-wrap .trail-canvas {
        position: absolute;
        left: 0;
        top: 0;
        display: block;
        width: 100%;
        height: 100%;
        image-rendering: -webkit-optimize-contrast;
        image-rendering: crisp-edges;
    }

    .trail-zoom-hint {
        font-size: 11px;
        color: #9db3dd;
        margin-top: 6px;
    }

    .legend-wrap {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        margin-top: 8px;
        font-size: 12px;
        color: #eaf2ff;
    }

    .legend-item {
        display: inline-flex;
        align-items: center;
        gap: 6px;
    }

    .legend-chip {
        width: 12px;
        height: 12px;
        border-radius: 3px;
    }

    .live-shell .text-secondary {
        color: #cfe1ff !important;
    }

    .live-shell .form-label {
        color: #eef5ff;
        font-weight: 600;
    }

    .live-shell .form-control,
    .live-shell .form-range {
        background-color: #0d1628;
        color: #f3f8ff;
        border-color: #35517f;
    }

    .behavior-panel {
        background: linear-gradient(180deg, #0d1628 0%, #0a101c 100%);
        border: 1px solid #35517f;
        border-radius: 10px;
        font-size: 12px;
    }

    .behavior-panel .bh-item {
        padding: 4px 10px;
        border-radius: 8px;
        background: #152238;
        border: 1px solid #2a4570;
        color: #e8f0ff;
    }

    @@media (max-width: 992px) {
        .monitor-grid {
            grid-template-columns: 1fr;
        }
    }
</style>

<nav class="mb-2" aria-label="breadcrumb">
    <ol class="breadcrumb small mb-0">
        <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Home</a></li>
        <li class="breadcrumb-item active" aria-current="page">Live tracking &amp; behavior</li>
    </ol>
</nav>
<div class="row g-2 mb-2">
    <div class="col-12">
        <h4 class="mb-1">Real-Time Human Tracking &amp; Behavior Analysis</h4>
        <p class="text-muted small mb-0">Multi-signal fusion: face and hand tracks, stable gestures and affect, scene motion, and engagement proxies. API port 5078.</p>
    </div>
</div>

<div class="row g-3">
    <div class="col-12 col-xl-8">
        <div class="monitor-grid">
            <div>
                <div class="monitor-title">Original Screen</div>
                <div class="live-stack">
                    <video id="video" autoplay playsinline class="live-video"></video>
                </div>
            </div>
            <div>
                <div class="monitor-title">Trailing Analytics Screen (Last 30s)</div>
                <div class="live-stack">
                    <canvas id="overlay" class="live-overlay"></canvas>
                </div>
            </div>
        </div>
        <div class="trail-stack">
            <div class="monitor-title">Trail Analytics Canvas (Eyes/Ears/Nose/Lips/Hand/Fingers)</div>
            <div id="trailCanvasWrap" class="trail-canvas-wrap">
                <canvas id="trailCanvas" class="trail-canvas"></canvas>
            </div>
            <div class="trail-zoom-hint">Trail map matches camera frame 1:1 (same pixel space as overlays). W×H shown in JSON panel when running.</div>
            <div class="legend-wrap">
                <span class="legend-item"><span class="legend-chip" style="background:#00d4ff;"></span>Eyes Left</span>
                <span class="legend-item"><span class="legend-chip" style="background:#ffd54a;"></span>Eyes Right</span>
                <span class="legend-item"><span class="legend-chip" style="background:#c77dff;"></span>Ear Left</span>
                <span class="legend-item"><span class="legend-chip" style="background:#40e0d0;"></span>Ear Right</span>
                <span class="legend-item"><span class="legend-chip" style="background:#7cfc4f;"></span>Nose</span>
                <span class="legend-item"><span class="legend-chip" style="background:#ff5ccf;"></span>Lips</span>
                <span class="legend-item"><span class="legend-chip" style="background:#00ff9d;"></span>Hand</span>
                <span class="legend-item"><span class="legend-chip" style="background:#ff8a3d;"></span>Fingers</span>
            </div>
        </div>
        <canvas id="captureCanvas" class="d-none"></canvas>
        <div class="hud">
            <span class="hud-badge">Faces: <span id="facesCount">0</span></span>
            <span class="hud-badge">Hands: <span id="handsCount">0</span></span>
            <span class="hud-badge">Eyes: <span id="eyesCount">0</span></span>
            <span class="hud-badge">Ears: <span id="earsCount">0</span></span>
            <span class="hud-badge">Lips: <span id="lipsCount">0</span></span>
            <span class="hud-badge">Movement: <span id="movementPct">0</span>%</span>
            <span class="hud-badge">Gesture: <span id="gestureName">-</span></span>
            <span class="hud-badge">Emotion: <span id="stableEmotion">Neutral</span></span>
            <span class="hud-badge">EyeState: <span id="oneEyeStatus">BothOpen</span></span>
            <span class="hud-badge">WS: <span id="wsState">Disconnected</span></span>
        </div>
        <div class="behavior-panel mt-2 p-3">
            <div class="monitor-title">Behavior &amp; tracking analysis</div>
            <div class="d-flex flex-wrap gap-2 mt-2 align-items-center">
                <span class="bh-item">Activity <strong id="bhActivity">0</strong>/100</span>
                <span class="bh-item">Scene <strong id="bhScene">—</strong></span>
                <span class="bh-item">Interaction <strong id="bhInteraction">—</strong></span>
                <span class="bh-item">Posture <strong id="bhPosture">—</strong></span>
                <span class="bh-item">Engagement <strong id="bhEngage">0</strong>/100</span>
                <span class="bh-item">Est. persons <strong id="htPersons">0</strong></span>
                <span class="bh-item">Primary speed <strong id="htSpeed">0</strong> px/f</span>
            </div>
            <div class="mt-2 small text-secondary" id="bhBehaviors">Behaviors: —</div>
        </div>
    </div>
    <div class="col-12 col-xl-4">
        <div class="card live-shell">
            <div class="card-body">
                <h5>Session controls</h5>
                <p class="text-secondary mb-2">UI port 5080 · API 5078</p>
                <div class="mb-2">
                    <label class="form-label">API Base Url</label>
                    <input id="apiBaseUrl" class="form-control" value="@apiBaseUrl" />
                </div>
                <div class="mb-2">
                    <label class="form-label">Session Id</label>
                    <input id="sessionId" class="form-control" />
                </div>
                <div class="d-flex gap-2 mb-2">
                    <button id="startBtn" class="btn btn-primary btn-sm">Start</button>
                    <button id="stopBtn" class="btn btn-secondary btn-sm">Stop</button>
                    <button id="calibrateBtn" class="btn btn-outline-primary btn-sm">Calibrate</button>
                </div>
                <div class="ops-grid mb-2">
                    <button id="recordTrailBtn" class="btn btn-sm btn-warning">Start Trail Rec</button>
                    <button id="snapshotBtn" class="btn btn-sm btn-success">Snapshot PNG</button>
                </div>
                <div class="mb-2">
                    <button id="downloadReportBtn" class="btn btn-sm btn-info w-100">Download JSON Session Report</button>
                </div>
                <div class="mb-2">
                    <button id="downloadCsvBtn" class="btn btn-sm btn-outline-info w-100">Download CSV Timeline</button>
                </div>
                <div class="mb-2">
                    <label class="form-label">Processing FPS</label>
                    <input id="processFps" type="range" min="1" max="1000" value="20" class="form-range" />
                    <small><span id="processFpsValue">20</span> fps</small>
                </div>
                <div class="mb-2 form-check">
                    <input class="form-check-input" type="checkbox" id="halfResolution">
                    <label class="form-check-label" for="halfResolution">Use half image resolution per frame (0.5x)</label>
                </div>
                <div class="mb-2">
                    <label class="form-label">Confidence Threshold (%)</label>
                    <input id="threshold" type="range" min="10" max="95" value="60" class="form-range" />
                    <small id="thresholdValue">60%</small>
                </div>
                <div class="mb-2">
                    <label class="form-label">Trail Length (sec)</label>
                    <input id="trailSeconds" type="range" min="2" max="30" value="10" class="form-range" />
                    <small><span id="trailSecondsValue">10</span>s</small>
                </div>
                <div class="mb-2">
                    <label class="form-label">Overlay Controls</label>
                    <div class="d-flex flex-wrap gap-2">
                        <div class="form-check form-check-inline">
                            <input class="form-check-input" type="checkbox" id="showFaces" checked>
                            <label class="form-check-label" for="showFaces">Faces</label>
                        </div>
                        <div class="form-check form-check-inline">
                            <input class="form-check-input" type="checkbox" id="showHands" checked>
                            <label class="form-check-label" for="showHands">Hands</label>
                        </div>
                        <div class="form-check form-check-inline">
                            <input class="form-check-input" type="checkbox" id="showTrail" checked>
                            <label class="form-check-label" for="showTrail">Trail</label>
                        </div>
                        <div class="form-check form-check-inline">
                            <input class="form-check-input" type="checkbox" id="showLabels" checked>
                            <label class="form-check-label" for="showLabels">Labels</label>
                        </div>
                        <div class="form-check form-check-inline">
                            <input class="form-check-input" type="checkbox" id="showEars" checked>
                            <label class="form-check-label" for="showEars">Ears</label>
                        </div>
                        <div class="form-check form-check-inline">
                            <input class="form-check-input" type="checkbox" id="showLips" checked>
                            <label class="form-check-label" for="showLips">Lips</label>
                        </div>
                        <div class="form-check form-check-inline">
                            <input class="form-check-input" type="checkbox" id="showNose" checked>
                            <label class="form-check-label" for="showNose">Nose</label>
                        </div>
                    </div>
                </div>
                <pre id="output" class="small bg-black text-info p-2 border rounded" style="height:280px; overflow:auto;"></pre>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.7/signalr.min.js"></script>
<script src="~/js/sceneSharedClient.js"></script>
<script>
(() => {
    const video = document.getElementById('video');
    const overlay = document.getElementById('overlay');
    const trailCanvas = document.getElementById('trailCanvas');
    const trailCanvasWrap = document.getElementById('trailCanvasWrap');
    const captureCanvas = document.getElementById('captureCanvas');
    const output = document.getElementById('output');
    const sessionIdInput = document.getElementById('sessionId');
    const apiBaseUrlInput = document.getElementById('apiBaseUrl');
    const thresholdInput = document.getElementById('threshold');
    const thresholdValue = document.getElementById('thresholdValue');
    const facesCount = document.getElementById('facesCount');
    const handsCount = document.getElementById('handsCount');
    const eyesCount = document.getElementById('eyesCount');
    const earsCount = document.getElementById('earsCount');
    const lipsCount = document.getElementById('lipsCount');
    const movementPct = document.getElementById('movementPct');
    const gestureName = document.getElementById('gestureName');
    const stableEmotion = document.getElementById('stableEmotion');
    const oneEyeStatus = document.getElementById('oneEyeStatus');
    const wsState = document.getElementById('wsState');
    const showFaces = document.getElementById('showFaces');
    const showHands = document.getElementById('showHands');
    const showTrail = document.getElementById('showTrail');
    const showLabels = document.getElementById('showLabels');
    const showEars = document.getElementById('showEars');
    const showLips = document.getElementById('showLips');
    const showNose = document.getElementById('showNose');
    const recordTrailBtn = document.getElementById('recordTrailBtn');
    const snapshotBtn = document.getElementById('snapshotBtn');
    const downloadReportBtn = document.getElementById('downloadReportBtn');
    const downloadCsvBtn = document.getElementById('downloadCsvBtn');
    const trailSecondsInput = document.getElementById('trailSeconds');
    const trailSecondsValue = document.getElementById('trailSecondsValue');
    const processFpsInput = document.getElementById('processFps');
    const processFpsValue = document.getElementById('processFpsValue');
    const halfResolutionInput = document.getElementById('halfResolution');
    let lastProcessedFrameNo = 0;
    const handTrail = [];
    let isRecordingTrail = false;
    const faceState = new Map();
    const handState = new Map();
    const eyeState = new Map();
    const lipsState = new Map();
    const earLeftState = new Map();
    const earRightState = new Map();
    const sessionStatsHistory = [];
    const gestureCounts = {};
    const sessionStartedAt = new Date().toISOString();
    const trailSeries = {
        eyesLeft: [],
        eyesRight: [],
        earsLeft: [],
        earsRight: [],
        nose: [],
        lips: [],
        hand: [],
        fingers: []
    };

    sessionIdInput.value = `ui-${crypto.randomUUID().slice(0, 8)}`;
    trailSecondsValue.textContent = trailSecondsInput.value;
    processFpsValue.textContent = processFpsInput.value;

    thresholdInput.addEventListener('input', async () => {
        thresholdValue.textContent = `${thresholdInput.value}%`;
        await postSettings();
    });
    trailSecondsInput.addEventListener('input', () => {
        trailSecondsValue.textContent = trailSecondsInput.value;
    });
    processFpsInput.addEventListener('input', async () => {
        processFpsValue.textContent = processFpsInput.value;
        await postSettings();
    });

    [showFaces, showHands, showTrail, showLabels, showEars, showLips, showNose].forEach(el => {
        el.addEventListener('change', () => postSettings());
    });

    document.getElementById('startBtn').addEventListener('click', start);
    document.getElementById('stopBtn').addEventListener('click', stop);
    document.getElementById('calibrateBtn').addEventListener('click', calibrate);
    recordTrailBtn.addEventListener('click', toggleTrailRecording);
    snapshotBtn.addEventListener('click', saveSnapshot);
    downloadReportBtn.addEventListener('click', downloadSessionReport);
    downloadCsvBtn.addEventListener('click', downloadCsvTimeline);

    function baseUrl() { return apiBaseUrlInput.value.replace(/\/$/, ''); }
    function sid() { return sessionIdInput.value.trim(); }
    const transport = SceneSharedClient.createDetectionTransport({
        getBaseUrl: () => baseUrl(),
        getSessionId: () => sid(),
        onConnectionModeChanged: (mode) => { wsState.textContent = mode; }
    });
    const processor = SceneSharedClient.createFrameProcessor({
        videoElement: video,
        getConstraints: () => ({ video: true, audio: false }),
        getTargetFps: () => Math.max(1, Number(processFpsInput.value || 20)),
        onFrame: ({ frameNo }) => processFrame(frameNo)
    });

    async function start() {
        await processor.start();
        processor.resetFrameCounter();
        await transport.initializeSession();
        await postSettings();
        await transport.connect();
    }

    async function stop() {
        await processor.stop();
        await transport.disconnect();
        await transport.cleanupSession();
    }

    function toggleTrailRecording() {
        isRecordingTrail = !isRecordingTrail;
        recordTrailBtn.textContent = isRecordingTrail ? "Stop Trail Rec" : "Start Trail Rec";
        recordTrailBtn.classList.toggle("btn-warning", !isRecordingTrail);
        recordTrailBtn.classList.toggle("btn-danger", isRecordingTrail);
        if (!isRecordingTrail) {
            handTrail.length = 0;
        }
    }

    function saveSnapshot() {
        if (!overlay.width || !overlay.height) return;
        const exportCanvas = document.createElement("canvas");
        exportCanvas.width = overlay.width;
        exportCanvas.height = overlay.height;
        const exportCtx = exportCanvas.getContext("2d");
        exportCtx.drawImage(video, 0, 0, overlay.width, overlay.height);
        exportCtx.drawImage(overlay, 0, 0);
        const url = exportCanvas.toDataURL("image/png");
        const a = document.createElement("a");
        a.href = url;
        a.download = `gesture_snapshot_${new Date().toISOString().replace(/[:.]/g, "-")}.png`;
        a.click();
    }

    function downloadSessionReport() {
        const report = {
            sessionId: sid(),
            startedAt: sessionStartedAt,
            exportedAt: new Date().toISOString(),
            apiBaseUrl: baseUrl(),
            settings: {
                confidenceThresholdPercent: Number(thresholdInput.value),
                trailSeconds: Number(trailSecondsInput.value),
                overlays: {
                    faces: showFaces.checked,
                    hands: showHands.checked,
                    trail: showTrail.checked,
                    labels: showLabels.checked
                }
            },
            summary: {
                totalFramesCaptured: lastProcessedFrameNo,
                timelinePoints: sessionStatsHistory.length,
                gesturesDetected: gestureCounts,
                systemName: "Real-Time Human Tracking & Behavior Analysis"
            },
            timeline: sessionStatsHistory
        };

        const blob = new Blob([JSON.stringify(report, null, 2)], { type: "application/json" });
        const url = URL.createObjectURL(blob);
        const a = document.createElement("a");
        a.href = url;
        a.download = `session_report_${sid()}_${new Date().toISOString().replace(/[:.]/g, "-")}.json`;
        a.click();
        URL.revokeObjectURL(url);
    }

    function downloadCsvTimeline() {
        const rows = [["timestamp","frame","faces","hands","eyes","movement","fps","gesture"]];
        sessionStatsHistory.forEach(item => {
            rows.push([
                item.at,
                item.frameNumber,
                item.faces,
                item.hands,
                item.eyes,
                item.movement,
                item.fps,
                item.gesture || ""
            ]);
        });

        const csv = rows.map(r => r.map(value => {
            const s = String(value ?? "");
            return s.includes(",") || s.includes("\"") ? `"${s.replace(/"/g, "\"\"")}"` : s;
        }).join(",")).join("\n");

        const blob = new Blob([csv], { type: "text/csv;charset=utf-8;" });
        const url = URL.createObjectURL(blob);
        const a = document.createElement("a");
        a.href = url;
        a.download = `session_timeline_${sid()}_${new Date().toISOString().replace(/[:.]/g, "-")}.csv`;
        a.click();
        URL.revokeObjectURL(url);
    }

    async function calibrate() {
        const r = await fetch(`${baseUrl()}/api/detection/calibrate/${encodeURIComponent(sid())}`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ frameCount: 45 })
        });
        output.textContent = JSON.stringify(await r.json(), null, 2);
    }

    async function postSettings() {
        const t = Number(thresholdInput.value) / 100;
        const targetFps = Number(processFpsInput.value || 20);
        const needFacePipeline = showFaces.checked || showEars.checked || showLips.checked || showNose.checked;
        await fetch(`${baseUrl()}/api/detection/settings/${encodeURIComponent(sid())}`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
                targetFPS: targetFps,
                movementThreshold: 25,
                faceConfidenceThreshold: t,
                handConfidenceThreshold: t,
                enableFaceDetection: needFacePipeline,
                enableEyeDetection: showFaces.checked,
                enableHandDetection: showHands.checked,
                enableExpressionDetection: showFaces.checked,
                enableGestureDetection: showHands.checked,
                enableMovementDetection: true,
                enableTextDetection: true,
                cameraStabilityThreshold: 60,
                enableWebSocketStreaming: true,
                maxTrackedHands: 2
            })
        });
    }

    async function processFrame(frameNo) {
        lastProcessedFrameNo = frameNo;
        const sourceWidth = video.videoWidth || 640;
        const sourceHeight = video.videoHeight || 360;
        const scale = halfResolutionInput.checked ? 0.5 : 1.0;
        const width = Math.max(160, Math.round(sourceWidth * scale));
        const height = Math.max(90, Math.round(sourceHeight * scale));
        captureCanvas.width = width;
        captureCanvas.height = height;
        overlay.width = sourceWidth;
        overlay.height = sourceHeight;
        trailCanvas.width = sourceWidth;
        trailCanvas.height = sourceHeight;
        if (trailCanvasWrap && sourceWidth > 0 && sourceHeight > 0) {
            trailCanvasWrap.style.aspectRatio = `${sourceWidth} / ${sourceHeight}`;
        }

        const captureCtx = captureCanvas.getContext('2d');
        captureCtx.drawImage(video, 0, 0, sourceWidth, sourceHeight, 0, 0, width, height);
        const imageData = captureCanvas.toDataURL('image/jpeg', 0.6);

        const payload = {
            sessionId: sid(),
            frameNumber: frameNo,
            timestamp: Date.now(),
            imageData
        };

        const data = await transport.processFrame(payload);
        if (data?.__httpError) {
            output.textContent = `API error ${data.status}: ${data.text || ''}`;
            return;
        }

        drawOverlay(data);
        updateSessionAnalytics(data);
        updateBehaviorHud(data);
        output.textContent = JSON.stringify({
            success: data.success,
            trailFrame: { width: trailCanvas.width, height: trailCanvas.height },
            faces: data.stats?.facesDetected,
            eyes: data.stats?.eyesDetected,
            ears: data.stats?.earsDetected,
            hands: data.stats?.handsDetected,
            movement: data.stats?.currentMovementLevel,
            behaviorAnalysis: data.behaviorAnalysis,
            humanTracking: data.humanTracking,
            calibration: data.calibration
        }, null, 2);
    }

    function updateBehaviorHud(data) {
        const ba = data?.behaviorAnalysis || {};
        const ht = data?.humanTracking || {};
        const setText = (id, text) => {
            const el = document.getElementById(id);
            if (el) el.textContent = text;
        };
        setText("bhActivity", Number(ba.activityScore ?? 0).toFixed(0));
        setText("bhScene", ba.sceneDynamics ?? "—");
        setText("bhInteraction", ba.interactionLevel ?? "—");
        setText("bhPosture", ba.posture ?? "—");
        setText("bhEngage", Number(ba.engagementLevel ?? 0).toFixed(0));
        setText("htPersons", String(ht.estimatedPersonCount ?? 0));
        setText("htSpeed", Number(ht.primarySubjectSpeed ?? 0).toFixed(1));
        const behaviors = Array.isArray(ba.detectedBehaviors) ? ba.detectedBehaviors : [];
        setText("bhBehaviors", behaviors.length ? `Behaviors: ${behaviors.join(", ")}` : "Behaviors: —");
    }

    function updateSessionAnalytics(data) {
        const stats = data?.stats || {};
        const detections = data?.detections || {};
        const dominantGesture = detections?.hands?.[0]?.gesture?.type || data?.handGestures?.[0]?.type || null;

        if (dominantGesture) {
            gestureCounts[dominantGesture] = (gestureCounts[dominantGesture] || 0) + 1;
        }

        sessionStatsHistory.push({
            at: new Date().toISOString(),
            frameNumber: lastProcessedFrameNo,
            faces: stats.facesDetected ?? 0,
            hands: stats.handsDetected ?? 0,
            eyes: stats.eyesDetected ?? 0,
            movement: stats.currentMovementLevel ?? 0,
            fps: stats.currentFPS ?? 0,
            gesture: dominantGesture
        });

        if (sessionStatsHistory.length > 2000) {
            sessionStatsHistory.shift();
        }
    }

    /** Nose tip estimate: inter-ocular midpoint + downward offset when 2+ eyes; fallback to face-box proportions. */
    function computeNosePoint(faceBbox, eyes, nowMs) {
        if (!faceBbox || faceBbox.width <= 0 || faceBbox.height <= 0) return null;
        const f = faceBbox;
        const fh = f.height;
        const eyeCenters = (eyes || [])
            .map(e => boxCenter(e.bBox))
            .filter(c => c && Number.isFinite(c.x) && Number.isFinite(c.y));
        if (eyeCenters.length >= 2) {
            const sorted = [...eyeCenters].sort((a, b) => a.x - b.x);
            const left = sorted[0];
            const right = sorted[sorted.length - 1];
            const mx = (left.x + right.x) / 2;
            const my = (left.y + right.y) / 2;
            const tipY = my + fh * 0.12;
            return { x: mx, y: tipY, t: nowMs };
        }
        if (eyeCenters.length === 1) {
            const c = eyeCenters[0];
            return { x: c.x, y: c.y + fh * 0.16, t: nowMs };
        }
        return { x: f.x + f.width * 0.5, y: f.y + fh * 0.50, t: nowMs };
    }

    function drawOverlay(data) {
        const ctx = overlay.getContext('2d');
        ctx.clearRect(0, 0, overlay.width, overlay.height);

        const detections = data?.detections || {};
        const faces = stabilizeDetections(detections.faces || [], faceState, "face");
        const hands = stabilizeDetections(detections.hands || [], handState, "hand");
        const eyes = stabilizeDetections(detections.eyes || [], eyeState, "eye");
        const earsList = detections.ears || [];
        const earsLeftRaw = earsList.filter(e => (e.side || "").toLowerCase() === "left");
        const earsRightRaw = earsList.filter(e => (e.side || "").toLowerCase() === "right");
        const earsLeft = stabilizeDetections(earsLeftRaw, earLeftState, "earL");
        const earsRight = stabilizeDetections(earsRightRaw, earRightState, "earR");
        const lipsRaw = (detections.objects || []).filter(o => (o.type || "").toLowerCase() === "lips");
        const lips = stabilizeDetections(lipsRaw, lipsState, "lips");
        const movement = Number(data?.stats?.currentMovementLevel || 0);
        const monitoringState = data?.monitoringState || {};
        const nowMs = Date.now();

        facesCount.textContent = faces.length;
        handsCount.textContent = hands.length;
        eyesCount.textContent = eyes.length;
        earsCount.textContent = earsLeft.length + earsRight.length;
        lipsCount.textContent = lips.length;
        movementPct.textContent = movement.toFixed(1);

        const dominantGesture = monitoringState.stableGesture || hands[0]?.gesture?.type || data?.handGestures?.[0]?.type || "-";
        gestureName.textContent = dominantGesture;
        stableEmotion.textContent = monitoringState.stableDominantEmotion || faceEmotionFallback(data);
        oneEyeStatus.textContent = monitoringState.oneEyeClosed
            ? `OneEyeClosed(${monitoringState.oneEyeClosedSide || "Unknown"})`
            : "BothOpen";

        if (showFaces.checked) {
            faces.forEach(face => {
                drawBox(ctx, face.bBox, "#24d8ff", `Face ${(face.confidence * 100).toFixed(0)}%`);
                if (showLabels.checked && face.expression?.dominantEmotion) {
                    drawTag(ctx, face.bBox.x, face.bBox.y - 20, `Mood: ${face.expression.dominantEmotion}`);
                }
            });
        }

        if (showHands.checked) {
            hands.forEach(hand => {
                const label = hand.gesture?.type
                    ? `${hand.gesture.type} ${(hand.gesture.confidence * 100).toFixed(0)}%`
                    : `Hand ${(hand.confidence * 100).toFixed(0)}%`;
                drawBox(ctx, hand.bBox, "#00ff9d", label);

                drawHandSkeleton(ctx, hand, "#7fffd4");

                const center = boxCenter(hand.bBox);
                if (showTrail.checked) {
                    handTrail.push({ ...center, t: nowMs });
                }
                trailSeries.hand.push({ x: center.x, y: center.y, t: nowMs });
                const fingerTips = extractFingerTips(hand);
                fingerTips.forEach(p => trailSeries.fingers.push({ x: p.x, y: p.y, t: nowMs }));
            });
        }

        const trailWindowMs = Number(trailSecondsInput.value || 10) * 1000;
        const cutoff = Date.now() - trailWindowMs;
        while (handTrail.length && handTrail[0].t < cutoff) {
            handTrail.shift();
        }

        if (showTrail.checked && showHands.checked) {
            drawTrail(ctx, handTrail, "#00ff9d");
        }

        if (showFaces.checked) {
            eyes.forEach(eye => {
                drawBox(ctx, eye.bBox, "#ffd54a", eye.gaze || "Eye");
            });
        }

        if (showEars.checked) {
            earsLeft.forEach(ear => {
                drawBox(ctx, ear.bBox, "#c77dff", "Ear L");
                const c = boxCenter(ear.bBox);
                trailSeries.earsLeft.push({ x: c.x, y: c.y, t: nowMs });
            });
            earsRight.forEach(ear => {
                drawBox(ctx, ear.bBox, "#40e0d0", "Ear R");
                const c = boxCenter(ear.bBox);
                trailSeries.earsRight.push({ x: c.x, y: c.y, t: nowMs });
            });
        }

        if (showLips.checked) {
            lips.forEach(lip => {
                drawBox(ctx, lip.bBox, "#ff5ccf", "Lips");
                const c = boxCenter(lip.bBox);
                trailSeries.lips.push({ x: c.x, y: c.y, t: nowMs });
            });
        }

        if (showFaces.checked && eyes.length > 0) {
            const avgEyeX = eyes.reduce((sum, e) => sum + (e.bBox?.x ?? 0), 0) / eyes.length;
            eyes.forEach(eye => {
                const c = boxCenter(eye.bBox);
                if ((eye.bBox?.x ?? 0) <= avgEyeX) {
                    trailSeries.eyesLeft.push({ x: c.x, y: c.y, t: nowMs });
                } else {
                    trailSeries.eyesRight.push({ x: c.x, y: c.y, t: nowMs });
                }
            });
        }

        if (showNose.checked && faces.length > 0) {
            const np = computeNosePoint(faces[0].bBox, eyes, nowMs);
            if (np) {
                trailSeries.nose.push(np);
                ctx.strokeStyle = "#7cfc4f";
                ctx.lineWidth = 2;
                ctx.beginPath();
                ctx.arc(np.x, np.y, 4, 0, Math.PI * 2);
                ctx.stroke();
            }
        }

        drawTrailCanvas();
    }

    function drawBox(ctx, b, color, label) {
        if (!b) return;
        ctx.lineWidth = 2;
        ctx.strokeStyle = color;
        ctx.strokeRect(b.x, b.y, b.width, b.height);
        if (showLabels.checked) {
            drawTag(ctx, b.x, b.y - 6, label, color);
        }
    }

    function drawTag(ctx, x, y, text, color = "#16213a") {
        ctx.font = "12px Segoe UI";
        const pad = 6;
        const tw = ctx.measureText(text).width;
        const tx = Math.max(0, x);
        const ty = Math.max(14, y);
        ctx.fillStyle = color;
        ctx.fillRect(tx, ty - 12, tw + pad * 2, 14);
        ctx.fillStyle = "#ffffff";
        ctx.fillText(text, tx + pad, ty - 2);
    }

    function drawTrail(ctx, points, color) {
        if (points.length < 2) return;
        ctx.beginPath();
        ctx.strokeStyle = color;
        ctx.lineWidth = 2;
        ctx.moveTo(points[0].x, points[0].y);
        for (let i = 1; i < points.length; i++) {
            ctx.lineTo(points[i].x, points[i].y);
        }
        ctx.stroke();
    }

    function drawTrailCanvas() {
        const ctx = trailCanvas.getContext('2d');
        const w = trailCanvas.width;
        const h = trailCanvas.height;
        ctx.fillStyle = "#040812";
        ctx.fillRect(0, 0, w, h);
        drawTrailGrid(ctx, w, h);

        const trailWindowMs = Number(trailSecondsInput.value || 10) * 1000;
        const cutoff = Date.now() - trailWindowMs;
        Object.values(trailSeries).forEach(arr => {
            while (arr.length && arr[0].t < cutoff) {
                arr.shift();
            }
        });

        if (showFaces.checked) {
            drawSeries(ctx, trailSeries.eyesLeft, "#00d4ff");
            drawSeries(ctx, trailSeries.eyesRight, "#ffd54a");
        }
        if (showNose.checked) {
            drawSeries(ctx, trailSeries.nose, "#7cfc4f");
        }
        if (showEars.checked) {
            drawSeries(ctx, trailSeries.earsLeft, "#c77dff");
            drawSeries(ctx, trailSeries.earsRight, "#40e0d0");
        }
        if (showLips.checked) {
            drawSeries(ctx, trailSeries.lips, "#ff5ccf");
        }
        if (showHands.checked) {
            drawSeries(ctx, trailSeries.hand, "#00ff9d");
            drawSeries(ctx, trailSeries.fingers, "#ff8a3d");
        }
    }

    function drawTrailGrid(ctx, w, h) {
        ctx.strokeStyle = "rgba(80, 120, 180, 0.22)";
        ctx.lineWidth = 1;
        for (let i = 1; i < 10; i++) {
            const x = (w * i) / 10;
            const y = (h * i) / 10;
            ctx.beginPath();
            ctx.moveTo(x, 0);
            ctx.lineTo(x, h);
            ctx.stroke();
            ctx.beginPath();
            ctx.moveTo(0, y);
            ctx.lineTo(w, y);
            ctx.stroke();
        }
        ctx.strokeStyle = "rgba(120, 160, 220, 0.35)";
        ctx.beginPath();
        ctx.moveTo(w / 2, 0);
        ctx.lineTo(w / 2, h);
        ctx.stroke();
        ctx.beginPath();
        ctx.moveTo(0, h / 2);
        ctx.lineTo(w, h / 2);
        ctx.stroke();
    }

    function drawSeries(ctx, points, color) {
        if (!Array.isArray(points) || points.length === 0) return;
        if (points.length === 1) {
            ctx.fillStyle = color;
            ctx.beginPath();
            ctx.arc(points[0].x, points[0].y, 2.5, 0, Math.PI * 2);
            ctx.fill();
            return;
        }
        ctx.beginPath();
        ctx.strokeStyle = color;
        ctx.lineWidth = 2;
        ctx.lineJoin = "round";
        ctx.lineCap = "round";
        ctx.moveTo(points[0].x, points[0].y);
        for (let i = 1; i < points.length; i++) {
            ctx.lineTo(points[i].x, points[i].y);
        }
        ctx.stroke();
    }

    function drawHandSkeleton(ctx, hand, color) {
        const points = hand?.landmarks || hand?.gesture?.keyPoints || [];
        if (!Array.isArray(points) || points.length < 2) return;

        const normalized = points
            .filter(p => typeof p.x === "number" && typeof p.y === "number")
            .map(p => ({ x: p.x, y: p.y }));

        if (normalized.length < 2) return;

        const scaled = normalized.map(p => ({
            x: normalizeToPixels(p.x, hand.bBox.x, hand.bBox.width, overlay.width),
            y: normalizeToPixels(p.y, hand.bBox.y, hand.bBox.height, overlay.height)
        }));

        ctx.strokeStyle = color;
        ctx.lineWidth = 1.5;
        ctx.beginPath();
        ctx.moveTo(scaled[0].x, scaled[0].y);
        for (let i = 1; i < scaled.length; i++) {
            ctx.lineTo(scaled[i].x, scaled[i].y);
        }
        ctx.stroke();

        ctx.fillStyle = color;
        scaled.forEach(p => {
            ctx.beginPath();
            ctx.arc(p.x, p.y, 2.2, 0, Math.PI * 2);
            ctx.fill();
        });
    }

    function faceEmotionFallback(data) {
        return data?.faceExpressions?.[0]?.dominantEmotion || "Neutral";
    }

    function stabilizeDetections(list, stateMap, type) {
        const now = performance.now();
        const keepMs = 900;
        const alpha = 0.25;
        const stable = [];

        list.forEach((item, idx) => {
            if (!item?.bBox) return;
            const key = `${type}-${item.trackId ?? idx}`;
            const prev = stateMap.get(key);
            const b = item.bBox;

            if (!prev) {
                stateMap.set(key, {
                    box: { x: b.x, y: b.y, width: b.width, height: b.height },
                    item,
                    lastSeen: now
                });
            } else {
                prev.box.x = prev.box.x + alpha * (b.x - prev.box.x);
                prev.box.y = prev.box.y + alpha * (b.y - prev.box.y);
                prev.box.width = prev.box.width + alpha * (b.width - prev.box.width);
                prev.box.height = prev.box.height + alpha * (b.height - prev.box.height);
                prev.item = item;
                prev.lastSeen = now;
                stateMap.set(key, prev);
            }
        });

        for (const [key, value] of stateMap.entries()) {
            if ((now - value.lastSeen) > keepMs) {
                stateMap.delete(key);
                continue;
            }

            stable.push({
                ...value.item,
                bBox: {
                    ...value.item.bBox,
                    x: value.box.x,
                    y: value.box.y,
                    width: value.box.width,
                    height: value.box.height
                }
            });
        }

        return stable;
    }

    function normalizeToPixels(value, boxStart, boxSize, maxSize) {
        if (value >= 0 && value <= 1) {
            return boxStart + value * boxSize;
        }
        return Math.max(0, Math.min(maxSize, value));
    }

    function boxCenter(b) {
        return { x: b.x + b.width / 2, y: b.y + b.height / 2 };
    }

    function extractFingerTips(hand) {
        const points = hand?.landmarks || hand?.gesture?.keyPoints || [];
        if (!Array.isArray(points) || points.length === 0 || !hand?.bBox) {
            return [];
        }

        const tipIndexes = [4, 8, 12, 16, 20];
        return tipIndexes
            .filter(i => i < points.length)
            .map(i => points[i])
            .filter(p => typeof p.x === "number" && typeof p.y === "number")
            .map(p => ({
                x: normalizeToPixels(p.x, hand.bBox.x, hand.bBox.width, overlay.width),
                y: normalizeToPixels(p.y, hand.bBox.y, hand.bBox.height, overlay.height)
            }));
    }
})();
</script>
}
