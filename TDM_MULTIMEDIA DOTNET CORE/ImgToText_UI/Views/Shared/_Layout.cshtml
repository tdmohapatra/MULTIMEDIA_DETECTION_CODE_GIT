<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Multimedia UI</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ImgToText_UI.styles.css" asp-append-version="true" />
</head>
<body class="app-body">
    <header class="app-header border-bottom shadow-sm">
        <nav class="navbar navbar-expand-md navbar-dark bg-dark py-2">
            <div class="container-fluid">
                <a class="navbar-brand fw-semibold" asp-controller="Home" asp-action="Index">Multimedia UI</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav" aria-controls="mainNav" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="mainNav">
                    <ul class="navbar-nav me-auto mb-2 mb-md-0">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" id="featuresDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">Features</a>
                            <ul class="dropdown-menu dropdown-menu-dark" aria-labelledby="featuresDropdown">
                                <li>
                                    <a class="dropdown-item" asp-controller="DetectionClient" asp-action="DetectionView">Live tracking &amp; behavior</a>
                                </li>
                                <li>
                                    <a class="dropdown-item" asp-controller="DetectionClient" asp-action="SceneAnalysis">Scene: humans / animals / objects</a>
                                </li>
                                <li><hr class="dropdown-divider" /></li>
                                <li>
                                    <a class="dropdown-item" asp-controller="Home" asp-action="Privacy">Privacy</a>
                                </li>
                            </ul>
                        </li>
                    </ul>
                    <div class="d-flex align-items-center gap-2">
                        <label class="small text-light mb-0" for="uiThemeSelect">Theme</label>
                        <select id="uiThemeSelect" class="form-select form-select-sm" style="min-width:140px;">
                            <option value="theme-cyberpunk">Cyberpunk</option>
                            <option value="theme-neon">Neon</option>
                            <option value="theme-minimal">Minimal</option>
                        </select>
                    </div>
                </div>
            </div>
        </nav>
    </header>
    <div class="container py-3 pb-5">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer app-footer text-muted small">
        <div class="container py-2">
            <span>&copy; @DateTime.UtcNow.Year Multimedia UI</span>
            <span class="mx-2">·</span>
            <a asp-controller="Home" asp-action="Privacy">Privacy</a>
            <span class="mx-2">·</span>
            <a asp-controller="DetectionClient" asp-action="DetectionView">Live detection</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        (function () {
            const storageKey = 'unified-theme';
            const select = document.getElementById('uiThemeSelect');
            const allowed = ['theme-cyberpunk', 'theme-neon', 'theme-minimal'];
            const saved = localStorage.getItem(storageKey);
            const theme = allowed.includes(saved) ? saved : 'theme-cyberpunk';
            document.body.classList.remove(...allowed);
            document.body.classList.add(theme);
            if (select) {
                select.value = theme;
                select.addEventListener('change', () => {
                    const next = allowed.includes(select.value) ? select.value : 'theme-cyberpunk';
                    document.body.classList.remove(...allowed);
                    document.body.classList.add(next);
                    localStorage.setItem(storageKey, next);
                });
            }
        })();
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
