            </button>
            <div class="mobile-brand">
                <i class="fas fa-eye"></i>
                <span>AI Vision</span>
            </div>
            <div class="mobile-status">
                <span class="mobile-fps" id="mobileFps">0 FPS</span>
                <div class="status-indicator status-offline" id="mobileProcessingStatus"></div>
            </div>
        </div>
    </div>

    <!-- Main Container -->
    <div class="rt-main-container">
        <!-- Sidebar for Desktop -->
        <div class="rt-sidebar d-none d-lg-block" id="sidebar">
            <div class="sidebar-header">
                <div class="brand">
                    <div class="brand-icon">
