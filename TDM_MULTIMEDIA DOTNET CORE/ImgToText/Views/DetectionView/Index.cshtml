                <a href="#" class="nav-item active" data-mode="dashboard">
                    <i class="fas fa-home"></i>
                    <span class="nav-text">Dashboard</span>
                </a>
                <a href="#" class="nav-item" data-mode="face-detection">
                    <i class="fas fa-user"></i>
                    <span class="nav-text">Face Detection</span>
                </a>
                <a href="#" class="nav-item" data-mode="hand-gestures">
                    <i class="fas fa-hand-paper"></i>
                    <span class="nav-text">Hand Gestures</span>
                </a>
                <a href="#" class="nav-item" data-mode="movement-analysis">
                    <i class="fas fa-running"></i>
                    <span class="nav-text">Movement</span>
                </a>
                <a href="#" class="nav-item" data-mode="text-detection">
                    <i class="fas fa-font"></i>
                    <span class="nav-text">Text OCR</span>
                </a>
                <a href="#" class="nav-item" data-mode="analytics">
                    <i class="fas fa-chart-line"></i>
