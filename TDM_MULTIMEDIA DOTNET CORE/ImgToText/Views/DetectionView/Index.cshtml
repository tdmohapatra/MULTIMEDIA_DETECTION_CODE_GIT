@section Scripts {
    <script src="~/js/realtime-detection.js"></script>
}

<!-- API Configuration -->
<script>
    // API endpoints configuration
    const apiConfig = {
        baseUrl: '@Url.Content("~/")',
        endpoints: {
            processFrame: '@Url.Action("ProcessFrame", "Detection")',
            startSession: '@Url.Action("StartSession", "Detection")',
            stopSession: '@Url.Action("StopSession", "Detection")',
            updateSettings: '@Url.Action("UpdateSettings", "Detection")',
            getStats: '@Url.Action("GetSessionStats", "Detection")',
            exportData: '@Url.Action("ExportData", "Detection")',
            healthCheck: '@Url.Action("HealthCheck", "Detection")'
        },
        sessionId: '@sessionId',
        settings: @Html.Raw(Json.Serialize(settings)),
        isMobile: @isMobile.ToString().ToLower()
    };
</script>

@section Scripts {
    <script src="~/js/realtime-detection.js" asp-append-version="true"></script>
    <script>
        // Initialize the real-time detection system
        document.addEventListener('DOMContentLoaded', function() {
            try {
                const detectionApp = new RealTimeDetectionApp(apiConfig);
                window.detectionApp = detectionApp; // Make available globally for debugging

                // Initialize with settings from server
                detectionApp.initialize().then(() => {
                    console.log('AI Vision System initialized successfully');
                }).catch(error => {
                    console.error('Failed to initialize AI Vision System:', error);
                    detectionApp.showError('Initialization failed: ' + error.message);
                });
            } catch (error) {
                console.error('Critical initialization error:', error);
                // Show error to user
                const errorToast = document.getElementById('errorToast');
                const errorMessage = document.getElementById('errorMessage');
                if (errorToast && errorMessage) {
                    errorMessage.textContent = 'Failed to initialize application: ' + error.message;
                    errorToast.classList.add('show');
                    setTimeout(() => {
                        errorToast.classList.remove('show');
                    }, 5000);
                }
            }
        });
    </script>
}

