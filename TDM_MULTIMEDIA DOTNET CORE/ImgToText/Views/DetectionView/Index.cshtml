@* STAR_MUTIMEDIA/Views/Detection/RealTimeDetection.cshtml *@
@using STAR_MUTIMEDIA.Models
@{
    ViewData["Title"] = "AI Vision - Real-Time Detection";
    Layout = "~/Views/Shared/_Layout.cshtml";

    // Create view model using your existing models
    var sessionId = Guid.NewGuid().ToString();
    var isMobile = Context.Request.Headers["User-Agent"].ToString().Contains("Mobi", StringComparison.OrdinalIgnoreCase);
    var settings = new DetectionSettings();
    var currentTime = DateTime.Now.ToString("HH:mm:ss");
}

<style>
    /* Add these to your existing RealTimeDetection.css file */

    /* Detection Switches */
    .detection-switches {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 0.5rem;
        margin-top: 0.5rem;
    }

    .form-switch {
        padding-left: 2.5em;
    }

        .form-switch .form-check-input {
            width: 2em;
            margin-left: -2.5em;
            background-color: var(--border-color);
            border-color: var(--border-light);
        }

            .form-switch .form-check-input:checked {
                background-color: var(--primary-color);
                border-color: var(--primary-color);
            }

        .form-switch .form-check-label {
            font-size: 0.85rem;
            color: var(--text-secondary);
        }

    /* Threshold Control */
    .threshold-control {
        margin-top: 0.5rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .form-range-sm {
        height: 4px;
    }

        .form-range-sm::-webkit-slider-thumb {
            width: 12px;
            height: 12px;
        }

    /* Video Status Bar */
    .video-status-bar {
        display: flex;
        justify-content: space-between;
        margin-top: 1rem;
        padding: 0.5rem;
        background: rgba(0, 0, 0, 0.2);
        border-radius: var(--radius-sm);
        font-size: 0.85rem;
    }

    .status-item {
        display: flex;
        align-items: center;
        gap: 0.25rem;
    }

    .status-label {
        color: var(--text-muted);
    }

    .status-value {
        color: var(--text-primary);
        font-weight: 500;
    }

    /* Card Actions Dropdown */
    .dropdown-menu {
        background: var(--card-bg);
        border: 1px solid var(--border-color);
        box-shadow: var(--shadow-lg);
    }

    .dropdown-item {
        color: var(--text-primary);
        font-size: 0.85rem;
        padding: 0.5rem 1rem;
    }

        .dropdown-item:hover {
            background: var(--card-hover);
            color: var(--text-primary);
        }

        .dropdown-item i {
            width: 1rem;
            margin-right: 0.5rem;
        }

    /* Loading Progress */
    .progress-bar-striped {
        background-image: linear-gradient( 45deg, rgba(255, 255, 255, 0.15) 25%, transparent 25%, transparent 50%, rgba(255, 255, 255, 0.15) 50%, rgba(255, 255, 255, 0.15) 75%, transparent 75%, transparent );
        background-size: 1rem 1rem;
    }

    .progress-bar-animated {
        animation: progress-bar-stripes 1s linear infinite;
    }

    @@keyframes progress-bar-stripes {
        from

    {
        background-position: 1rem 0;
    }

    to {
        background-position: 0 0;
    }

    }

    /* Connection Status */
    .connection-status {
        position: fixed;
        bottom: 1rem;
        right: 1rem;
        background: var(--warning-color);
        color: white;
        padding: 0.5rem 1rem;
        border-radius: var(--radius-md);
        display: none;
        align-items: center;
        gap: 0.5rem;
        z-index: 9999;
        box-shadow: var(--shadow-lg);
    }

        .connection-status.connected {
            background: var(--success-color);
        }

        .connection-status.disconnected {
            background: var(--danger-color);
        }

        .connection-status.show {
            display: flex;
            animation: slideInUp 0.3s ease;
        }

    .connection-indicator {
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    /* Success Toast */
    .success-toast {
        position: fixed;
        bottom: 1rem;
        left: 1rem;
        background: var(--success-color);
        color: white;
        padding: 1rem;
        border-radius: var(--radius-md);
        display: none;
        align-items: center;
        gap: 1rem;
        max-width: 400px;
        z-index: 9999;
        box-shadow: var(--shadow-lg);
        transform: translateY(100px);
        opacity: 0;
        transition: all 0.3s ease;
    }

        .success-toast.show {
            transform: translateY(0);
            opacity: 1;
            display: flex;
        }

        .success-toast .toast-content {
            display: flex;
            align-items: center;
            gap: 1rem;
            flex: 1;
        }

        .success-toast .toast-body {
            display: flex;
            flex-direction: column;
        }

        .success-toast .toast-title {
            font-size: 0.9rem;
            font-weight: 600;
            margin-bottom: 0.25rem;
        }

        .success-toast .toast-message {
            font-size: 0.85rem;
            opacity: 0.9;
        }

    /* Settings Tabs */
    .settings-tabs {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .settings-group {
        background: rgba(255, 255, 255, 0.05);
        border-radius: var(--radius-md);
        padding: 1rem;
    }

    .settings-group-title {
        font-size: 1rem;
        font-weight: 600;
        margin-bottom: 1rem;
        color: var(--text-primary);
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .settings-option {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 0.75rem 0;
        border-bottom: 1px solid var(--border-color);
    }

        .settings-option:last-child {
            border-bottom: none;
        }

    .settings-label {
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
    }

    .settings-name {
        font-weight: 500;
        color: var(--text-primary);
    }

    .settings-description {
        font-size: 0.85rem;
        color: var(--text-secondary);
    }

    .settings-control {
        min-width: 100px;
    }

    /* Mobile Optimizations */
    @@media (max-width: 768px) {
        .detection-switches

    {
        grid-template-columns: 1fr;
    }

    .video-status-bar {
        flex-direction: column;
        gap: 0.5rem;
    }

    .status-item {
        justify-content: space-between;
    }

    .connection-status {
        left: 1rem;
        right: 1rem;
        bottom: 0.5rem;
    }

    .success-toast,
    .error-toast {
        left: 0.5rem;
        right: 0.5rem;
        max-width: none;
    }

    }

    /* Dark mode adjustments for form controls */
    @@media (prefers-color-scheme: dark) {
        .form-range::-webkit-slider-thumb

    {
        background: var(--primary-color);
    }

    .form-range::-moz-range-thumb {
        background: var(--primary-color);
    }

    .form-switch .form-check-input {
        background-color: var(--border-light);
    }

    }

    /* Accessibility improvements */
    @@media (prefers-reduced-motion: reduce) {
        .progress-bar-animated, .success-toast, .error-toast, .connection-status

    {
        animation: none;
        transition: none;
    }

    }

    /* Print styles */
    @@media print {
        .rt-sidebar, .mobile-header, .mobile-controls-bar, .top-nav, .mode-selector-container, .detection-mode-selector, .card-action-btn, .video-controls-overlay, .tabs-header, .btn-clear-logs, .dropdown, .modal, .toast, .connection-status

    {
        display: none !important;
    }

    .rt-main-container {
        flex-direction: column;
    }

    .card {
        break-inside: avoid;
        border: 1px solid #ccc;
        box-shadow: none;
    }

    .video-container {
        display: none;
    }

    }
</style>
<div class="rt-app-container" data-session="@sessionId" data-mobile="@isMobile.ToString().ToLower()">
