                                <h3 class="card-title">
                                    <i class="fas fa-video"></i>
                                    Live Camera Feed
                                </h3>
                                <div class="card-actions">
                                    <div class="fps-display">
                                        <span id="liveFps">0 FPS</span>
                                        <div class="status-indicator status-offline"></div>
                                    </div>
                                    <div class="dropdown">
                                        <button class="card-action-btn dropdown-toggle" type="button" data-bs-toggle="dropdown">
                                            <i class="fas fa-cog"></i>
                                        </button>
                                        <ul class="dropdown-menu dropdown-menu-end">
                                            <li><a class="dropdown-item" href="#" id="toggleCameraBtn"><i class="fas fa-camera"></i> Toggle Camera</a></li>
                                            <li><a class="dropdown-item" href="#" id="flipCameraBtn"><i class="fas fa-sync-alt"></i> Flip Camera</a></li>
                                            <li><a class="dropdown-item" href="#" id="fullscreenBtn"><i class="fas fa-expand"></i> Fullscreen</a></li>
                                            <li><hr class="dropdown-divider"></li>
                                            <li><a class="dropdown-item" href="#" id="cameraSettingsBtn"><i class="fas fa-sliders-h"></i> Camera Settings</a></li>
                                        </ul>
                                    </div>
                                </div>
                            </div>
                            <div class="card-body">
                                <div class="video-container">
                                    <video id="videoFeed" autoplay muted playsinline></video>
                                    <canvas id="processingCanvas"></canvas>
                                    <div id="videoOverlay"></div>
                                    <div class="video-controls-overlay">
                                        <button class="video-control-btn" id="quickFlipCameraBtn" title="Flip Camera">
                                            <i class="fas fa-sync-alt"></i>
                                        </button>
                                        <button class="video-control-btn" id="quickFullscreenBtn" title="Fullscreen">
                                            <i class="fas fa-expand"></i>
                                        </button>
                                    </div>
                                </div>
                                <div class="video-status-bar">
                                    <div class="status-item">
                                        <span class="status-label">Resolution:</span>
                                        <span class="status-value" id="videoResolution">--x--</span>
                                    </div>
                                    <div class="status-item">
                                        <span class="status-label">FPS:</span>
                                        <span class="status-value" id="videoFps">0</span>
                                    </div>
                                    <div class="status-item">
                                        <span class="status-label">Status:</span>
                                        <span class="status-value" id="videoStatus">Offline</span>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Detection Controls -->
                        <div class="card controls-card">
                            <div class="card-header">
                                <h3 class="card-title">
                                    <i class="fas fa-sliders-h"></i>
                                    Detection Controls
                                </h3>
                                <button class="card-action-btn" id="resetControlsBtn" title="Reset to defaults">
                                    <i class="fas fa-redo"></i>
                                </button>
                            </div>
                            <div class="card-body">
                                <div class="controls-grid">
                                    <div class="control-group">
                                        <label class="control-label">
                                            <i class="fas fa-tachometer-alt me-1"></i>
                                            Processing Rate
                                        </label>
                                        <div class="range-control">
                                            <input type="range" class="form-range" id="fpsSlider" min="5" max="60" value="@settings.TargetFPS">
                                            <div class="range-value">
                                                <span id="fpsValue">@settings.TargetFPS</span> FPS
                                            </div>
                                        </div>
                                    </div>
                                    <div class="control-group">
                                        <label class="control-label">
                                            <i class="fas fa-bullseye me-1"></i>
                                            Sensitivity
                                        </label>
                                        <div class="range-control">
                                            <input type="range" class="form-range" id="sensitivityRange" min="1" max="100" value="50">
                                            <div class="range-value">
                                                <span id="sensitivityValue">50%</span>
                                            </div>
