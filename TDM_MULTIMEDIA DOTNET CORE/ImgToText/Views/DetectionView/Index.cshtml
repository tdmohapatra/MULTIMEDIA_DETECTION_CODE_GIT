                </a>
            </div>

            <div class="nav-section">
                <div class="nav-title">Detection Status</div>
                <div class="nav-item">
                    <i class="fas fa-user"></i>
                    <span class="nav-text">Faces</span>
                    <span class="nav-count" id="sidebarFaceCount">0</span>
                </div>
                <div class="nav-item">
                    <i class="fas fa-eye"></i>
                    <span class="nav-text">Eyes</span>
                    <span class="nav-count" id="sidebarEyeCount">0</span>
                </div>
                <div class="nav-item">
                    <i class="fas fa-hand-paper"></i>
                    <span class="nav-text">Hands</span>
                    <span class="nav-count" id="sidebarHandCount">0</span>
                </div>
                <div class="nav-item">
                    <i class="fas fa-running"></i>
                    <span class="nav-text">Movement</span>
                    <span class="nav-percent" id="sidebarMovementLevel">0%</span>
                </div>
            </div>

            <div class="nav-section">
                <div class="nav-title">System Status</div>
                <div class="nav-item">
                    <i class="fas fa-microchip"></i>
                    <span class="nav-text">AI Processing</span>
                    <div class="status-indicator status-offline" id="processingStatus"></div>
                </div>
                <div class="nav-item">
                    <i class="fas fa-video"></i>
                    <span class="nav-text">Camera Feed</span>
                    <div class="status-indicator status-offline" id="cameraStatus"></div>
                </div>
                <div class="nav-item">
                    <i class="fas fa-server"></i>
                    <span class="nav-text">System Health</span>
                    <div class="status-indicator status-online" id="systemStatus"></div>
                </div>
                <div class="nav-item">
                    <i class="fas fa-memory"></i>
                    <span class="nav-text">FPS</span>
                    <span class="nav-text" id="sidebarFps">0</span>
                </div>
            </div>

            <div class="sidebar-footer">
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <small class="text-muted">Session:</small>
                    <small id="sessionIdDisplay" class="session-id">@sessionId</small>
                </div>
                <div class="d-flex justify-content-between align-items-center">
                    <small class="text-muted">Uptime:</small>
                    <small id="uptimeDisplay">00:00:00</small>
                </div>
            </div>
        </div>

        <!-- Mobile Sidebar Overlay -->
        <div class="mobile-sidebar-overlay" id="mobileSidebarOverlay"></div>
        <div class="mobile-sidebar" id="mobileSidebar">
            <div class="mobile-sidebar-header">
                <div class="mobile-brand">
                    <i class="fas fa-eye"></i>
                    <span>AI Vision System</span>
                </div>
                <button class="mobile-sidebar-close">
                    <i class="fas fa-times"></i>
                </button>
            </div>
            <div class="mobile-nav-items">
                <a href="#" class="mobile-nav-item active" data-mode="dashboard">
                    <i class="fas fa-home"></i>
                    <span>Dashboard</span>
                </a>
                <a href="#" class="mobile-nav-item" data-mode="face-detection">
                    <i class="fas fa-user"></i>
                    <span>Face Detection</span>
                </a>
                <a href="#" class="mobile-nav-item" data-mode="hand-gestures">
                    <i class="fas fa-hand-paper"></i>
                    <span>Hand Gestures</span>
                </a>
                <a href="#" class="mobile-nav-item" data-mode="movement-analysis">
                    <i class="fas fa-running"></i>
                    <span>Movement Analysis</span>
                </a>
                <a href="#" class="mobile-nav-item" data-mode="text-detection">
                    <i class="fas fa-font"></i>
                    <span>Text OCR</span>
                </a>
                <a href="#" class="mobile-nav-item" data-mode="analytics">
                    <i class="fas fa-chart-line"></i>
                    <span>Analytics</span>
                </a>
                <a href="#" class="mobile-nav-item" data-mode="settings">
                    <i class="fas fa-cog"></i>
                    <span>Settings</span>
                </a>
            </div>
        </div>

        <!-- Main Content Area -->
        <div class="rt-content-area">
            <!-- Top Navigation Bar -->
            <div class="top-nav d-none d-lg-flex">
                <div class="d-flex align-items-center">
                    <button class="control-btn sidebar-toggle-btn" id="desktopSidebarToggle">
                        <i class="fas fa-bars"></i>
                    </button>
                    <h1 class="page-title">Real-Time Detection Dashboard</h1>
                </div>
                <div class="nav-controls">
                    <div class="d-flex align-items-center me-3">
                        <i class="fas fa-clock me-2"></i>
                        <span id="currentTime">@currentTime</span>
                    </div>
                    <button class="control-btn control-success" id="startBtn">
                        <i class="fas fa-play"></i>
                        <span class="d-none d-md-inline">Start</span>
                    </button>
                    <button class="control-btn control-danger" id="stopBtn" disabled>
                        <i class="fas fa-stop"></i>
                        <span class="d-none d-md-inline">Stop</span>
                    </button>
                    <button class="control-btn control-primary" id="exportBtn">
                        <i class="fas fa-download"></i>
                        <span class="d-none d-md-inline">Export</span>
                    </button>
                    <button class="control-btn control-warning" id="recalibrateBtn">
                        <i class="fas fa-sliders-h"></i>
                        <span class="d-none d-md-inline">Recalibrate</span>
                    </button>
                </div>
            </div>

            <!-- Mobile Controls Bar -->
            <div class="mobile-controls-bar d-lg-none">
                <button class="mobile-control-btn control-success" id="mobileStartBtn">
                    <i class="fas fa-play"></i>
                </button>
                <button class="mobile-control-btn control-danger" id="mobileStopBtn" disabled>
                    <i class="fas fa-stop"></i>
                </button>
                <div class="mobile-stats">
                    <span id="mobileFpsText">0 FPS</span>
                    <div class="status-indicator status-offline"></div>
                </div>
                <button class="mobile-control-btn control-primary" id="mobileExportBtn">
                    <i class="fas fa-download"></i>
                </button>
                <button class="mobile-control-btn control-warning" id="mobileRecalibrateBtn" title="Recalibrate">
                    <i class="fas fa-sliders-h"></i>
                </button>
            </div>

            <!-- Content Area -->
            <div class="content-wrapper">
                <!-- Mode Selector (Mobile Tabs) -->
                <div class="mode-selector-container d-lg-none">
                    <div class="mode-tabs" id="mobileModeTabs">
                        <button class="mode-tab active" data-mode="dashboard">
                            <i class="fas fa-home"></i>
                            <span>Dashboard</span>
                        </button>
                        <button class="mode-tab" data-mode="face-detection">
                            <i class="fas fa-user"></i>
                            <span>Face</span>
                        </button>
                        <button class="mode-tab" data-mode="hand-gestures">
                            <i class="fas fa-hand-paper"></i>
                            <span>Hands</span>
                        </button>
                        <button class="mode-tab" data-mode="analytics">
                            <i class="fas fa-chart-line"></i>
                            <span>Analytics</span>
                        </button>
                    </div>
                </div>

                <!-- Detection Mode Selector (Desktop) -->
                <div class="detection-mode-selector d-none d-lg-block" id="modeSelector">
                    <button class="mode-btn active" data-mode="dashboard">
                        <i class="fas fa-home me-2"></i>Dashboard
                    </button>
                    <button class="mode-btn" data-mode="face-detection">
                        <i class="fas fa-user me-2"></i>Face Detection
                    </button>
                    <button class="mode-btn" data-mode="hand-gestures">
                        <i class="fas fa-hand-paper me-2"></i>Hand Gestures
                    </button>
                    <button class="mode-btn" data-mode="movement-analysis">
                        <i class="fas fa-running me-2"></i>Movement Analysis
                    </button>
                    <button class="mode-btn" data-mode="text-detection">
                        <i class="fas fa-font me-2"></i>Text Detection
                    </button>
                    <button class="mode-btn" data-mode="analytics">
                        <i class="fas fa-chart-line me-2"></i>Analytics
                    </button>
                </div>

                <!-- Dashboard Mode -->
                <div class="detection-mode active" id="dashboard-mode">
                    <!-- Stats Overview Grid -->
                    <div class="stats-grid" id="statsGrid">
                        <div class="stat-card">
                            <div class="stat-icon">
                                <i class="fas fa-user"></i>
                            </div>
                            <div class="stat-content">
                                <div class="stat-value" id="faceCount">0</div>
                                <div class="stat-label">Faces</div>
                            </div>
                        </div>
                        <div class="stat-card">
                            <div class="stat-icon">
                                <i class="fas fa-eye"></i>
                            </div>
                            <div class="stat-content">
                                <div class="stat-value" id="eyeCount">0</div>
                                <div class="stat-label">Eyes</div>
                            </div>
                        </div>
                        <div class="stat-card">
                            <div class="stat-icon">
                                <i class="fas fa-hand-paper"></i>
                            </div>
                            <div class="stat-content">
                                <div class="stat-value" id="handCount">0</div>
                                <div class="stat-label">Hands</div>
                            </div>
                        </div>
                        <div class="stat-card">
                            <div class="stat-icon">
                                <i class="fas fa-project-diagram"></i>
                            </div>
                            <div class="stat-content">
                                <div class="stat-value" id="frameCount">0</div>
                                <div class="stat-label">Frames</div>
                            </div>
                        </div>
                    </div>

                    <!-- Video Feed Section -->
