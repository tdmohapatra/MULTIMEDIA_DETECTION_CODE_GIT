{
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "TessDataPath": "Uploads\\tessdata",
  "Cors": {
    "AllowedOrigins": [
      "https://your-domain.com"
    ]
  },
  "Session": {
    "UseRedis": true,
    "RedisInstanceName": "STAR_MUTIMEDIA",
    "IdleTimeoutMinutes": 30,
    "IOTimeoutSeconds": 10,
    "CookieName": ".STAR_MUTIMEDIA.Session"
  },
  "ConnectionStrings": {
    "Redis": "localhost:6379,abortConnect=false"
  },
  "Observability": {
    "MemorySamplingSeconds": 15,
    "MemoryWarningMb": 1200
  },
  "Security": {
    "MaxApiRequestBytes": 8388608,
    "MaxMultipartBytes": 16777216,
    "RateLimit": {
      "PermitLimit": 90,
      "WindowSeconds": 60,
      "QueueLimit": 10
    }
  },
  "AllowedHosts": "*",
  "Ocr": {
    "Provider": "paddleocr",
    "FallbackProvider": "tesseract"
  }
}
