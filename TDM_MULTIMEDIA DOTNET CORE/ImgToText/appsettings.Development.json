{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "TessDataPath": "Uploads\\tessdata",
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5078",
      "https://localhost:5078",
      "http://localhost:5080",
      "https://localhost:5080"
    ]
  },
  "Observability": {
    "MemorySamplingSeconds": 10,
    "MemoryWarningMb": 900
  },
  "Security": {
    "MaxApiRequestBytes": 10485760,
    "MaxMultipartBytes": 20971520,
    "RateLimit": {
      "PermitLimit": 200,
      "WindowSeconds": 60,
      "QueueLimit": 40
    }
  }
}
